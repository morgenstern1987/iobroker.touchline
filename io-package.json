{
  "common": {
    "name": "touchline",
    "version": "0.1.0",
    "title": "Roth Touchline Adapter",
    "desc": {
      "en": "Adapter for Roth Touchline heating controller",
      "de": "Adapter für Roth Touchline Heizungssteuerung"
    },
    "authors": [
      "Henrik Morgenstern"
    ],
    "keywords": [
      "touchline",
      "heating"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "type": "climate-control",
    "enabled": true,
    "materialize": true,
    "adminUI": {
      "config": "materialize"
    },
    "connectionType": "local",
    "dataSource": "poll",
    "loglevel": "info"
  },

  "native": {
    "host": "",
    "pollInterval": 30
  },

  "objects": [],

  "instanceObjects": [
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connection",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
