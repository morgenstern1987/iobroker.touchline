{
  "common": {
    "name": "touchline",
    "version": "0.1.0",
    "title": "Roth Touchline Adapter",
    "titleLang": {
      "en": "Roth Touchline Adapter",
      "de": "Roth Touchline Adapter"
    },
    "desc": {
      "en": "Adapter for Roth Touchline floor heating controller",
      "de": "Adapter für Roth Touchline Fußbodenheizung"
    },
    "authors": [
      "Henrik Morgenstern"
    ],
    "keywords": [
      "heating",
      "touchline",
      "floor heating"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "type": "climate-control",
    "enabled": true,
    "materialize": true,
    "adminUI": {
      "config": "materialize"
    },
    "connectionType": "local",
    "dataSource": "poll",
    "loglevel": "info",
    "icon": "touchline.png",
    "extIcon": "https://raw.githubusercontent.com/morgenstern1987/iobroker.touchline/main/admin/touchline.png",
    "readme": "https://github.com/morgenstern1987/iobroker.touchline",
    "compact": true
  },

  "native": {
    "host": "",
    "pollInterval": 30
  },

  "objects": [],

  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connected",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
