{
  "common": {
    "name": "touchline",
    "version": "0.1.0",
    "news": {
      "0.1.0": {
        "en": "Initial release – supports legacy CGI API and new SL REST API",
        "de": "Erstveröffentlichung – unterstützt Legacy-CGI-API und neue SL REST-API"
      }
    },
    "title": "Roth Touchline",
    "titleLang": {
      "en": "Roth Touchline Heating",
      "de": "Roth Touchline Heizung"
    },
    "desc": {
      "en": "Adapter for Roth Touchline and Touchline SL floor heating controllers (local network)",
      "de": "Adapter für Roth Touchline und Touchline SL Fußbodenheizungsregler (lokales Netzwerk)"
    },
    "authors": ["morgenstern1987 <morgenstern1987@github>"],
    "keywords": ["roth", "touchline", "heating", "floor heating", "SL"],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "icon": "admin/touchline.png",
    "mode": "daemon",
    "type": "climate-control",
    "enabled": true,
    "readme": "[github.com](https://github.com/morgenstern1987/iobroker.touchline/blob/main/README.md)",
    "loglevel": "info",
    "restartSchedule": "",
    "adminUI": {
      "config": "materialize"
    },
    "connectionType": "local",
    "dataSource": "poll",
    "messagebox": true
  },
  "native": {
    "host": "",
    "apiVersion": "auto",
    "pollInterval": 30,
    "requestTimeout": 5000
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Connected to controller",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
